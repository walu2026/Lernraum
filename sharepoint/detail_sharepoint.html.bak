function getParam(name) {
  // Hash (#101) statt ?id= weil SharePoint den ?id= Parameter selbst verwendet
  if (name === 'id') {
    const hash = window.location.hash.replace('#', '');
    if (hash) return hash;
  }
  return new URLSearchParams(window.location.search).get(name);
}

window.onload = function() {
  const id = getParam('id');
  const d = DATA[id];
  if (!d) { document.body.innerHTML = '<div style="padding:2rem">Nicht gefunden. <a href="https://bldsg.sharepoint.com/:f:/t/ABULernportal/IgARC7kSs6RURa9TJyrnBVH8AZPe0HR_0OutEDgeFoGXprg?e=99OxCs">Zurück</a></div>'; return; }

  document.title = 'ABU – ' + d.title;
  document.getElementById('dStripe').style.background = d.tc;
  document.getElementById('dHeadBody').style.background = d.tbg;
  document.getElementById('dNum').style.color = d.tc;
  document.getElementById('dNum').textContent = id;
  document.getElementById('dLabel').style.color = d.tc;
  document.getElementById('dLabel').textContent = d.label;
  document.getElementById('dTitle').textContent = d.title;
  document.getElementById('dDesc').textContent = d.desc;

  // T9 und T10: nur ein Ordner pro Kachel, kein Theorie/Übungen/Quiz
  const isT9  = id === '901' || id === '902';
  const isT10 = id === '1001' || id === '1002' || id === '1003';
  const files = (isT9 || isT10)
    ? [ { key: id+'_Theorie', icon:'📁', cls:'fi-t', name: d.title, hint:'SharePoint-Ordner öffnen' } ]
    : [
        { key: id+'_Theorie',  icon:'📘', cls:'fi-t', name: d.pre+'_Theorie '+d.title,  hint:'Erklärungen, Grundlagen' },
        { key: id+'_Übungen',  icon:'✏️', cls:'fi-e', name: d.pre+'_Übungen '+d.title,  hint:'Aufgaben, Fallbeispiele, Lernjobs' },
        { key: id+'_Quiz',     icon:'🧠', cls:'fi-q', name: d.pre+'_Quiz '+d.title,      hint:'Lernkontrolle, Self-Check' },
      ];

  const container = document.getElementById('fileCards');
  files.forEach(f => {
    const url = LINKS[f.key];
    const a = document.createElement('a');
    a.className = 'file-card' + (url ? '' : ' not-linked');
    a.style.setProperty('--tc', d.tc);
    a.href = url || '#';
    if (url) { a.target = '_blank'; a.rel = 'noopener noreferrer'; }
    a.innerHTML = `
      <div class="file-icon ${f.cls}">${f.icon}</div>
      <div class="file-body">
        <div class="file-name">${f.name}</div>
        <div class="file-hint">${url ? f.hint : '🔗 Noch kein Link hinterlegt'}</div>
      </div>
      <span class="file-arrow">${url ? '→' : ''}</span>`;
    container.appendChild(a);
  });
};
</script>
</body>
</html>
